# Directory to scan for Frappe bench instances (defaults to $HOME if not set)
# BENCH_MANAGER_BENCH_ROOT=/home/frappe

# Server binding
BENCH_MANAGER_HOST=0.0.0.0
BENCH_MANAGER_PORT=8500

# Change this to a random secret in production
BENCH_MANAGER_SECRET_KEY=change-me

# Path to the bench executable (leave blank to auto-detect)
# Set this if 'bench' is not on PATH, e.g. installed via pip in a virtualenv
# BENCH_MANAGER_BENCH_CMD=/home/frappe/.local/bin/bench
